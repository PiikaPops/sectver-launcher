{
  "name": "sectver-launcher",
  "version": "0.1.0",
  "description": "Sectver Minecraft Launcher",
  "main": "dist-electron/electron/main.js",
  "author": "Sectver",
  "private": true,
  "scripts": {
    "dev:vite": "vite",
    "dev:electron:build": "tsc -p electron/tsconfig.json",
    "dev:electron": "wait-on http://localhost:5173 && npm run dev:electron:build && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k -n VITE,ELECTRON -c magenta,cyan \"npm:dev:vite\" \"npm:dev:electron\"",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "start": "npm run build && electron .",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win --x64"
  },
  "dependencies": {
    "@types/adm-zip": "^0.5.8",
    "@xmcl/core": "^2.15.1",
    "@xmcl/installer": "^6.1.2",
    "adm-zip": "^0.5.17",
    "electron-updater": "^6.8.3",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.sectver.launcher",
    "productName": "Sectver Launcher",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "publish": {
      "provider": "github",
      "owner": "PiikaPops",
      "repo": "sectver-launcher"
    }
  }
}
